# Optional: Numista API (Valcoin — random catalog coin obverses via /api/numista-coins). https://en.numista.com/api/
# For localhost: copy to `.env.local` as NUMISTA_API_KEY=... then restart `npm run dev`.
# NUMISTA_API_KEY=

# Optional: override Firebase web config (defaults are in lib/firebaseClient.js).
# On Vercel: do not define these as empty strings — omit them or use real values, or Firebase breaks.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
